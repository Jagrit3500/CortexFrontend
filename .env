# ─── Backend Connection ───────────────────────────────────────
# Set this to your teammate's backend URL when ready
VITE_API_BASE_URL=http://localhost:8000/api

# ─── App Environment ──────────────────────────────────────────
VITE_APP_ENV=development

# ─── Feature Flags ────────────────────────────────────────────
# Set to 'true' to use mock data (when backend is not ready)
VITE_USE_MOCK=true
